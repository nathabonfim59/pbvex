{
  "name": "@pbvex/svelte",
  "version": "0.1.1",
  "type": "module",
  "description": "Svelte 5 rune utilities for reactive PBVex queries, mutations, and actions backed by @pbvex/client.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nathabonfim59/pbvex.git",
    "directory": "packages/svelte"
  },
  "homepage": "https://github.com/nathabonfim59/pbvex#readme",
  "bugs": "https://github.com/nathabonfim59/pbvex/issues",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "svelte": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "pnpm --filter @pbvex/client build && node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "pnpm run build && tsc --noEmit && vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@pbvex/protocol": "workspace:0.1.1"
  },
  "devDependencies": {
    "@pbvex/client": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "jsdom": "^24.0.0",
    "svelte": "^5.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.5.0"
  },
  "peerDependencies": {
    "@pbvex/client": "workspace:*",
    "svelte": "^5.0.0"
  }
}
