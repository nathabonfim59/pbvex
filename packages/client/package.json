{
  "name": "@pbvex/client",
  "version": "0.4.2",
  "type": "module",
  "description": "Browser-neutral PBVex client with typed calls and realtime subscriptions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nathabonfim59/pbvex.git",
    "directory": "packages/client"
  },
  "homepage": "https://github.com/nathabonfim59/pbvex#readme",
  "bugs": "https://github.com/nathabonfim59/pbvex/issues",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --filter @pbvex/protocol build && tsc",
    "dev": "tsc --watch",
    "test": "pnpm --filter @pbvex/protocol build && pnpm --filter pbvex build && tsc --noEmit -p tsconfig.test.json && vitest run",
    "lint": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@pbvex/protocol": "workspace:0.4.2"
  },
  "devDependencies": {
    "pbvex": "workspace:^",
    "typescript": "^5.0.0",
    "vitest": "^4.1.10"
  }
}
