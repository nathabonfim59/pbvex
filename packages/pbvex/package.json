{
  "name": "pbvex",
  "version": "0.2.3",
  "type": "module",
  "description": "PBVex CLI and runtime authoring SDK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nathabonfim59/pbvex.git",
    "directory": "packages/pbvex"
  },
  "homepage": "https://github.com/nathabonfim59/pbvex#readme",
  "bugs": "https://github.com/nathabonfim59/pbvex/issues",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "pbvex": "./dist/cli/index.js"
  },
  "main": "./dist/runtime/index.js",
  "types": "./dist/runtime/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/runtime/index.js",
      "types": "./dist/runtime/index.d.ts"
    },
    "./server": {
      "import": "./dist/runtime/server.js",
      "types": "./dist/runtime/server.d.ts"
    },
    "./values": {
      "import": "./dist/runtime/values.js",
      "types": "./dist/runtime/values.d.ts"
    },
    "./component": {
      "import": "./dist/runtime/component.js",
      "types": "./dist/runtime/component.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "tsc --noEmit -p tsconfig.test.json && vitest run",
    "lint": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@pbvex/protocol": "workspace:0.2.3",
    "@pbvex/server": "workspace:0.2.3",
    "commander": "^12.0.0",
    "chokidar": "^3.6.0",
    "zod": "^3.22.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
