{
  "name": "@pbvex/protocol",
  "version": "0.3.1",
  "type": "module",
  "description": "Shared PBVex deployment protocol, wire value codec, and canonical hashing",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nathabonfim59/pbvex.git",
    "directory": "packages/protocol"
  },
  "homepage": "https://github.com/nathabonfim59/pbvex#readme",
  "bugs": "https://github.com/nathabonfim59/pbvex/issues",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
